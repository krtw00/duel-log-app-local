{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "rootDir": "../src/main",
    "outDir": "../dist-electron/main",
    "noEmit": false
  },
  "include": ["../src/main/**/*"],
  "exclude": ["../src/main/**/*.test.ts"]
}
