{
  "name": "duel-log-app-local",
  "version": "2.0.2",
  "description": "Duel Log App - Local Electron Version (secured and updated)",
  "main": "dist-electron/main/index.js",
  "license": "MIT",
  "author": "krtw00",
  "repository": {
    "type": "git",
    "url": "https://github.com/krtw00/duel-log-app-local.git"
  },
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "vite build --config config/vite.config.ts && tsc -p config/tsconfig.main.json && tsc -p config/tsconfig.preload.json",
    "preview": "vite preview --config config/vite.config.ts",
    "electron:dev": "vite --mode development --config config/vite.config.ts",
    "electron:build": "npm run build && electron-builder",
    "test": "vitest run --config config/vitest.config.ts",
    "test:watch": "vitest --config config/vitest.config.ts",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "apexcharts": "^5.16.0",
    "better-sqlite3": "^12.11.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue3-apexcharts": "^1.11.1",
    "vuetify": "^4.1.3"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "sass-embedded": "^1.100.0",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.duellog.app",
    "productName": "Duel Log App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    }
  }
}
